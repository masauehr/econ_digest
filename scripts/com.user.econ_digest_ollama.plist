<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.user.econ_digest_ollama.plist — launchd設定ファイル（Ollama版）
  設置先: ~/Library/LaunchAgents/com.user.econ_digest_ollama.plist
  登録:   launchctl load ~/Library/LaunchAgents/com.user.econ_digest_ollama.plist
  手動実行: launchctl start com.user.econ_digest_ollama
  解除:   launchctl unload ~/Library/LaunchAgents/com.user.econ_digest_ollama.plist

  実行タイミング: 毎週金曜 09:00（Haiku版の13:00より4時間前）
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.user.econ_digest_ollama</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/masahiro/projects/econ_digest/scripts/run_econ_ollama.sh</string>
  </array>

  <!-- 実行スケジュール: 毎週金曜 09:00 -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>5</integer>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/Users/masahiro/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/anaconda3/bin</string>
    <key>HOME</key>
    <string>/Users/masahiro</string>
    <key>LANG</key>
    <string>ja_JP.UTF-8</string>
    <!-- モデルを変更する場合は以下のコメントを外して設定 -->
    <!-- <key>ECON_OLLAMA_MODEL</key> -->
    <!-- <string>qwen3.6:27b-mlx</string> -->
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/masahiro/projects/econ_digest/econ_digest.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/masahiro/projects/econ_digest/econ_digest.log</string>

  <key>RunAtLoad</key>
  <false/>

  <key>WorkingDirectory</key>
  <string>/Users/masahiro/projects/econ_digest</string>
</dict>
</plist>
